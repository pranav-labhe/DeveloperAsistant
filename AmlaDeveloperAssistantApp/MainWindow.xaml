<Window x:Class="AmlaDeveloperAssistantApp.MainWindow"
     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
     xmlns:local="clr-namespace:AmlaDeveloperAssistantApp"
     mc:Ignorable="d"
     Title="Amla Developer Assistant"
     Height="480"
     Width="360"
     WindowStartupLocation="Manual"  
     Background="#1E1E1E" >
 
    <Grid Margin="8">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header -->
            <RowDefinition Height="*"/>
            <!-- chat -->
            <RowDefinition Height="Auto"/>
            <!-- question -->
            <RowDefinition Height="Auto"/>
            <!-- buttons -->
            <RowDefinition Height="Auto"/>
            <!-- path -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <DockPanel Grid.Row="0" Margin="0,0,0,6">
 

                <TextBox x:Name="selectedpath"
                 Height="24"
                 Width="130"
                 Background="#2D2D30"
                 Foreground="White"
                 BorderBrush="#444"
                 Padding="5"
                 DockPanel.Dock="Left"
                 HorizontalAlignment="Stretch" FontSize="10"/>

            <Button Content="Browse"
                 Height="20"
                Width="55"
                Margin="6,0,0,0"
                Click="BrowseRepoPath"
                Background="#3A3D41"  FontSize="10"
                Foreground="White"/>

            <Button Content="Load Files"
                Click="OnRefreshProject"
                 Height="20"
                Width="70"
                Margin="6,0,0,0"
                Background="#3A3D41"  FontSize="10"
                Foreground="White"/>

            <Button Content="Load KB"
                Click="OnRefreshKB"
                Height="20"
                Width="55"
                Margin="6,0,0,0"
                Background="#3A3D41"  FontSize="10"
                Foreground="White"/>
        </DockPanel>

        <!-- CHAT AREA -->
        <ScrollViewer Grid.Row="1"
                  x:Name="ChatScroll"
                  VerticalScrollBarVisibility="Auto"
                  Margin="0,0,0,6">

            <StackPanel x:Name="ChatPanel"
                    Orientation="Vertical"/>
        </ScrollViewer>

        <!-- QUESTION INPUT -->
        <Grid Grid.Row="2" Margin="0,4,0,6">
            <TextBox x:Name="QuestionBox"
                     MinHeight="32"
                     MaxHeight="200"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Background="#2D2D30"
                     Foreground="White"
                     BorderBrush="#444"
                     Padding="6,6,48,6"
                     PreviewKeyDown="QuestionBox_PreviewKeyDown"
                     TextChanged="QuestionBox_TextChanged"/>
            <TextBlock Text="Ask anything"
                       Foreground="#888"
                       Padding="10,6,48,6"
                       IsHitTestVisible="False"
                       VerticalAlignment="Top"
                       Margin="2,0,0,0"
                       FontSize="13"
                       Visibility="{Binding Text.IsEmpty, ElementName=QuestionBox, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Content="Send"
                        Name="SendButton"
                        Click="OnSend"                        
                        Width="40"
                        Height="28"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,3,3,3"
                        Background="#0E639C"
                        Foreground="White"/>
        </Grid>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,0,0,6">

            
            <!--<Button Content="Send"
                Name="SendButton"
                Click="OnSend"
                Width="55" 
                Background="#0E639C"
                Foreground="White"/>-->
        </StackPanel>


    </Grid> 

</Window>
